{
  "name": "devtracker",
  "displayName": "DevTracker",
  "description": "Automatically tracks coding, reading, debugging, git operations, and terminal usage with local-first detailed analytics and a premium interactive dashboard.",
  "version": "1.0.1",
  "publisher": "jeem-labs",
  "icon": "icon.png",
  "keywords": [
    "productivity",
    "analytics",
    "time tracking",
    "coding stats",
    "developer",
    "activity",
    "git",
    "terminal",
    "AI",
    "heatmap",
    "wakatime",
    "dashboard"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ijahangirabbas/Dev-Activity-Tracker.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [
    "onCommand:devtracker.showDashboard",
    "onCommand:devtracker.exportData",
    "onCommand:devtracker.backupData",
    "onCommand:devtracker.restoreData",
    "onCommand:devtracker.syncToCloud",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "devtracker.showDashboard",
        "title": "DevTracker: Show Analytics Dashboard",
        "category": "DevTracker"
      },
      {
        "command": "devtracker.exportData",
        "title": "DevTracker: Export Analytics Data",
        "category": "DevTracker"
      },
      {
        "command": "devtracker.backupData",
        "title": "DevTracker: Backup Data",
        "category": "DevTracker"
      },
      {
        "command": "devtracker.restoreData",
        "title": "DevTracker: Restore Data",
        "category": "DevTracker"
      },
      {
        "command": "devtracker.syncToCloud",
        "title": "DevTracker: Sync Data to Cloud (Supabase)",
        "category": "DevTracker"
      }
    ],
    "configuration": {
      "title": "DevTracker",
      "properties": {
        "devTracker.idleTimeout": {
          "type": "integer",
          "default": 300,
          "enum": [
            60,
            180,
            300,
            600,
            900
          ],
          "enumDescriptions": [
            "1 Minute",
            "3 Minutes",
            "5 Minutes",
            "10 Minutes",
            "15 Minutes"
          ],
          "description": "Idle timeout in seconds (when tracking will pause)."
        },
        "devTracker.dailyGoal": {
          "type": "integer",
          "default": 14400,
          "description": "Daily development time goal in seconds (default is 4 hours)."
        },
        "devTracker.privacyMode": {
          "type": "boolean",
          "default": false,
          "description": "Privacy Mode: If true, obscure specific file names and workspace paths in logs."
        },
        "devTracker.recordRawTerminalCommands": {
          "type": "boolean",
          "default": false,
          "description": "If true, records the actual command line executed in terminal events. If false or in Privacy Mode, only the command category (e.g., git, build, test) is stored, and common secrets are redacted."
        },
        "devTracker.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show activity status in the status bar."
        },
        "devTracker.userId": {
          "type": "string",
          "default": "",
          "description": "Your cloud dashboard user UUID. Copy it from https://dev-activity-tracker-zeta.vercel.app/dashboard?tab=settings to sync local extension data to your account."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "package": "npm run typecheck && node esbuild.js --production"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "typescript": "^5.3.3"
  }
}
